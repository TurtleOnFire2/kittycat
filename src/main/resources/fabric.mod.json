{
  "schemaVersion": 1,
  "id": "kittycat",
  "version": "${version}",
  "name": "Kittycat",
  "description": "Kittycat client mod",
  "license": "MIT",
  "environment": "client",
  "accessWidener": "kittycat.accesswidener",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "kitty.cat.KittycatClient"
      }
    ]
  },
  "mixins": [
    {
      "config": "kittycat.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~26.2",
    "java": ">=25",
    "fabric-api": "*",
    "fabric-language-kotlin": ">=1.13.12+kotlin.2.4.0"
  }
}
